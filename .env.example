# 이 파일을 복사해서 .env 파일을 만드세요:
#   cp .env.example .env
# 그 다음 각 값을 실제 값으로 채우세요.

# Django
SECRET_KEY=여기에_랜덤_시크릿키_입력
DEBUG=False
ALLOWED_HOSTS=*

# Database (PostgreSQL)
DB_NAME=catechism_db
DB_USER=catechism_user
DB_PASSWORD=여기에_DB_비밀번호_입력
DB_HOST=127.0.0.1
DB_PORT=5432

# Email (Gmail SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=여기에_Gmail_주소_입력@gmail.com
EMAIL_HOST_PASSWORD=여기에_Gmail_앱_비밀번호_입력
DEFAULT_FROM_EMAIL=여기에_Gmail_주소_입력@gmail.com
